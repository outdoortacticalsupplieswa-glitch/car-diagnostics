generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Booking {
  id               String   @id @default(cuid())
  reference        String   @unique
  fullName         String
  contactNumber    String
  email            String
  vehicleModel     String
  vehicleType      String
  preferredDate    String
  serviceType      String
  issueDescription String
  serviceAddress   String
  createdAt        DateTime @default(now())
}
